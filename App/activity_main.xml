<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:gravity="center"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000" android:padding="24dp">
    <TextView android:text="Focus Lock" android:textSize="32sp" android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="Lock your phone. Keep your focus." android:textColor="#AAAAAA"
        android:layout_marginBottom="32dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <NumberPicker android:id="@+id/minutesPicker"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <Button android:id="@+id/startBtn" android:text="Start Lock"
        android:layout_marginTop="24dp" android:layout_width="match_parent" android:layout_height="56dp"/>
    <Button android:id="@+id/accessBtn" android:text="Enable Accessibility (required)"
        android:layout_marginTop="12dp" android:layout_width="match_parent" android:layout_height="48dp"/>
    <TextView android:layout_marginTop="40dp" android:text="built by CHIDI"
        android:textColor="#666666" android:textSize="12sp"
        android:layout_gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>
